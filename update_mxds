import arcpy
import os

# Set the root directory you want to scan
ROOT_DIR = r"E:\source location"
# The Master APRX that you manually created/copied in Windows
MASTER_APRX = r"E:\somewhere\destination.aprx"

def update_mxds_only():
    """
    Phase 2: Scans for .mxd files, imports them into ONE master .aprx project,
    renames the imported items, and dynamically repoints old .mdb links.
    Handles FME-generated suffix changes (e.g., _polygon, _line).
    """
    print("Starting Phase 2: The One APRX to Rule Them All...")
    
    # Check if the user manually created the Master APRX
    if not os.path.exists(MASTER_APRX):
        print(f"\nEEK! I can't find {MASTER_APRX}!")
        print("Please ensure your Master Project is created and closed in Pro.")
        return

    # Step 1: Build the "Treasure Map" of all existing GDBs
    print("Mapping out the new Geodatabases...")
    gdb_catalog = {}
    for dirpath, dirnames, filenames in os.walk(ROOT_DIR):
        for dirname in dirnames:
            if dirname.lower().endswith('.gdb'):
                gdb_catalog[dirname.lower()] = os.path.join(dirpath, dirname)
                
    print(f"Found {len(gdb_catalog)} GDBs to use for repointing.")

    # Cache for GDB contents so we don't have to scan the same GDB repeatedly
    gdb_contents_cache = {}
    
    print(f"Opening Master Project: {MASTER_APRX}")
    try:
        master_aprx = arcpy.mp.ArcGISProject(MASTER_APRX)
    except Exception as e:
        print(f"EEK! Could not open Master Project. Ensure it is not locked by ArcGIS Pro: {str(e)}")
        return

    # Step 2: Find MXDs and import them into the Master
    print("\n--- Importing MXDs ---")
    for dirpath, dirnames, filenames in os.walk(ROOT_DIR):
        for filename in filenames:
            if filename.lower().endswith('.mxd'):
                mxd_path = os.path.join(dirpath, filename)
                mxd_base = filename[:-4]
                
                print(f"\nProcessing: {filename}")
                
                try:
                    # Take a snapshot of existing maps/layouts BEFORE import
                    old_maps = [m.name for m in master_aprx.listMaps()]
                    old_layouts = [l.name for l in master_aprx.listLayouts()]
                    
                    # Import the old MXD
                    master_aprx.importDocument(mxd_path)
                    
                    # Find the newly imported maps and rename/update them
                    new_maps = [m for m in master_aprx.listMaps() if m.name not in old_maps]
                    for m in new_maps:
                        m.name = f"{mxd_base} - {m.name}"
                        print(f"  Imported Map: {m.name}")
                        
                        # Repoint layer connections dynamically
                        for lyr in m.listLayers():
                            if lyr.supports("CONNECTIONPROPERTIES"):
                                cp = lyr.connectionProperties
                                if cp and 'connection_info' in cp:
                                    db_path = cp['connection_info'].get('database', '')
                                    old_dataset = cp.get('dataset', '')
                                    
                                    # If it's pointing to an old MDB...
                                    if db_path.lower().endswith('.mdb'):
                                        db_name = os.path.basename(db_path).lower()
                                        gdb_name = db_name.replace('.mdb', '.gdb')
                                        
                                        if gdb_name in gdb_catalog:
                                            new_db_path = gdb_catalog[gdb_name]
                                            
                                            # Cache GDB contents on first visit
                                            if new_db_path not in gdb_contents_cache:
                                                arcpy.env.workspace = new_db_path
                                                fcs = arcpy.ListFeatureClasses() or []
                                                tbls = arcpy.ListTables() or []
                                                gdb_contents_cache[new_db_path] = {name.lower(): name for name in (fcs + tbls)}
                                            
                                            contents = gdb_contents_cache[new_db_path]
                                            new_dataset = old_dataset
                                            
                                            # Handle FME-appended geometry suffixes
                                            if old_dataset.lower() not in contents:
                                                for suffix in ['_polygon', '_line', '_point', '_annotation']:
                                                    guess = (old_dataset + suffix).lower()
                                                    if guess in contents:
                                                        new_dataset = contents[guess]
                                                        break
                                            else:
                                                new_dataset = contents[old_dataset.lower()]
                                            
                                            # Update workspace AND dataset name
                                            new_cp = dict(cp)
                                            new_cp['connection_info']['database'] = new_db_path
                                            new_cp['dataset'] = new_dataset
                                            new_cp['workspace_factory'] = 'File Geodatabase' 
                                            
                                            lyr.updateConnectionProperties(cp, new_cp)
                                            print(f"    Fixed link: '{lyr.name}' -> {os.path.basename(new_db_path)} \\ {new_dataset}")
                                        else:
                                            print(f"    WARNING: Could not find GDB for '{lyr.name}' ({db_name})")

                    # Find the newly imported layouts and rename them
                    new_layouts = [l for l in master_aprx.listLayouts() if l.name not in old_layouts]
                    for l in new_layouts:
                        l.name = f"{mxd_base} - {l.name}"
                        print(f"  Imported Layout: {l.name}")

                    # Save incrementally after every successful MXD import
                    master_aprx.save()
                    print(f"  Successfully merged {filename} into Master.")
                    
                except Exception as e:
                    print(f"  ERROR importing {filename}: {str(e)}")

    # Force Python to release the file lock
    del master_aprx
    print("\nUpgrade complete! Give Juno a peanut for me!")

if __name__ == '__main__':
    update_mxds_only()
